# Backend FastAPI principal.
#   Standalone:     http://localhost:8000
#   Docker compose: http://server:8000
BACKEND_URL=http://localhost:8000

# UUID de una casa real. El mock se autentica con X-Device-Token = casa.id.
# Para listar casas disponibles (con docker compose corriendo):
#   docker compose exec db psql -U mihogar_admin -d mihogar -c "SELECT id, nombre FROM casas LIMIT 5;"
MOCK_CASA_ID=

# Frecuencia de polling
CONFIG_POLL_SECONDS=15
HEARTBEAT_SECONDS=30

# Telemetría dummy random. Off por default. Encender solo para ver
# el dashboard con data viva durante desarrollo.
MOCK_SEND_TELEMETRY=false
TELEMETRY_SECONDS=60

# Logging stdlib: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Timeout HTTP read/write hacia el backend (connect fijo en 5s)
HTTP_TIMEOUT_SECONDS=10
