{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowConnect",
      "Effect": "Allow",
      "Action": "iot:Connect",
      "Resource": "arn:aws:iot:*:*:client/${iot:Connection.Thing.ThingName}"
    },
    {
      "Sid": "AllowPublish",
      "Effect": "Allow",
      "Action": "iot:Publish",
      "Resource": [
        "arn:aws:iot:*:*:topic/mihogar/*/telemetry",
        "arn:aws:iot:*:*:topic/mihogar/*/telemetry/batch",
        "arn:aws:iot:*:*:topic/mihogar/*/state",
        "arn:aws:iot:*:*:topic/mihogar/*/alerts",
        "arn:aws:iot:*:*:topic/mihogar/*/heartbeat",
        "arn:aws:iot:*:*:topic/mihogar/*/config/request",
        "arn:aws:iot:*:*:topic/mihogar/*/provisioning"
      ]
    },
    {
      "Sid": "AllowSubscribe",
      "Effect": "Allow",
      "Action": "iot:Subscribe",
      "Resource": [
        "arn:aws:iot:*:*:topicfilter/mihogar/*/commands",
        "arn:aws:iot:*:*:topicfilter/mihogar/*/config/response",
        "arn:aws:iot:*:*:topicfilter/mihogar/*/ml/profile"
      ]
    },
    {
      "Sid": "AllowReceive",
      "Effect": "Allow",
      "Action": "iot:Receive",
      "Resource": [
        "arn:aws:iot:*:*:topic/mihogar/*/commands",
        "arn:aws:iot:*:*:topic/mihogar/*/config/response",
        "arn:aws:iot:*:*:topic/mihogar/*/ml/profile"
      ]
    }
  ]
}
