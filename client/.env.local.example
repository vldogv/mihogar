# API del backend principal (cloud). En prod el rewrite de next.config.mjs maneja /api.
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Pi-hub local (Fase 6). Solo necesario en dev para simular "modo local"
# apuntando al pi-hub que corre en docker-compose (puerto 8081).
# En prod, la Pi sirve la PWA mismo-origen y este valor queda vacío:
# el probe a /health usa window.location.origin automáticamente.
# NEXT_PUBLIC_HUB_LOCAL_URL=http://localhost:8081
